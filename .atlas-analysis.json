  "keyFeatures": [
    "Create and manage invitation codes for controlled user sign-ups",
    "Send invitations via email with customizable handlers",
    "Automatically assign or upgrade user roles when invites are used",
    "Track invitation usage and enforce maximum uses per invite",
    "Support multiple token types (default, code, custom)",
    "Store tokens securely in browser cookies for seamless activation",
    "Comprehensive hooks system for customizing behavior",
    "Built-in permission system for invite operations",
    "Separate private and public invitation modes"
  ],
  "publicApiSurface": [
    "invite() - Server plugin function",
    "inviteClient() - Client plugin function",
    "POST /invite/create - Create an invitation",
    "POST /invite/activate - Activate an invitation token",
    "GET /invite/get - Get invitation details",
    "POST /invite/cancel - Cancel an invitation",
    "POST /invite/reject - Reject an invitation",
    "InviteOptions - Plugin configuration type",
    "InviteType - Invitation data type",
    "InviteSchema - Database schema definition"
  ]
